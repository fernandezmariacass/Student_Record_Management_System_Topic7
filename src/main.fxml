<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller"
            prefWidth="600" prefHeight="580">

    <!-- Header -->
    <Label text="Student Record Management System"
           AnchorPane.topAnchor="0"
           AnchorPane.leftAnchor="0"
           AnchorPane.rightAnchor="0"
           maxWidth="Infinity"
           alignment="CENTER"
           prefHeight="50"
           style="-fx-background-color: #F4A7B9; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #6B2D4E;"/>

    <Label text="Name:"        AnchorPane.topAnchor="70"  AnchorPane.leftAnchor="20"/>
    <TextField fx:id="txtName" AnchorPane.topAnchor="90"  AnchorPane.leftAnchor="20" prefWidth="200"/>

    <Label text="Course:"        AnchorPane.topAnchor="130" AnchorPane.leftAnchor="20"/>
    <TextField fx:id="txtCourse" AnchorPane.topAnchor="150" AnchorPane.leftAnchor="20" prefWidth="200"/>

    <Label text="Year Level:"  AnchorPane.topAnchor="190" AnchorPane.leftAnchor="20"/>
    <ChoiceBox fx:id="cbYear"  AnchorPane.topAnchor="210" AnchorPane.leftAnchor="20" prefWidth="200"/>

    <Button text="Add"    onAction="#addStudent"    AnchorPane.topAnchor="255" AnchorPane.leftAnchor="20"
            style="-fx-background-color: #F4A7B9; -fx-text-fill: #6B2D4E; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
    <Button text="Update" onAction="#updateStudent" AnchorPane.topAnchor="255" AnchorPane.leftAnchor="80"
            style="-fx-background-color: #F4A7B9; -fx-text-fill: #6B2D4E; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
    <Button text="Delete" onAction="#deleteStudent" AnchorPane.topAnchor="255" AnchorPane.leftAnchor="155"
            style="-fx-background-color: #F4A7B9; -fx-text-fill: #6B2D4E; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
    <Button text="Clear"  onAction="#clearFields"   AnchorPane.topAnchor="255" AnchorPane.leftAnchor="222"
            style="-fx-background-color: #F4A7B9; -fx-text-fill: #6B2D4E; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>

    <TableView fx:id="table"
               AnchorPane.topAnchor="305"
               AnchorPane.leftAnchor="20"
               AnchorPane.rightAnchor="20"
               AnchorPane.bottomAnchor="20">
        <columns>
            <TableColumn fx:id="colId"     text="ID"     prefWidth="50"/>
            <TableColumn fx:id="colName"   text="Name"   prefWidth="150"/>
            <TableColumn fx:id="colCourse" text="Course" prefWidth="150"/>
            <TableColumn fx:id="colYear"   text="Year"   prefWidth="100"/>
        </columns>
    </TableView>

</AnchorPane>
